---
import Layout from "../../layouts/Layout.astro";
import { type CollectionEntry, getCollection } from "astro:content";

// map though all products to create a page for each one
export async function getStaticPaths() {
  const products = await getCollection("products");

  return products.map((product) => ({
    params: { id: product.id },
    props: product
  }));
}
type Props = CollectionEntry<"products">;

// get the product data from the props to use in the template below. The actual data is in product.data
const product = Astro.props as Partial<Props>;
const data = product?.data;
const productId = data?.id ?? data?.Id;
const hasProduct = Boolean(data && productId);
const title = hasProduct ? (data?.name ?? "Product") : "Product Not Found";
---
<Layout title = {title}>
    <script src="../../js/product.ts"></script>
  
    <!-- Product details will go here -->
    <section class="product-detail">
    {hasProduct ? (
      <>
    <h3>{data?.brand?.name || data?.brand || 'Brand'}</h3>

    <h2 class="divider">{data?.nameWithoutBrand || data?.name}</h2>

    <img
        class="divider"
        src={data?.images?.primaryExtraLarge || data?.image || '/banner.jpg'}
        alt={data?.nameWithoutBrand || data?.name || 'Product'}
    />

    <p class="product-card__price">{data?.finalPrice || data?.price || 'Price TBA'}</p>

    <p class="product__color">{data?.colors?.[0]?.colorName || data?.color || ''}</p>

    <p class="product__description" set:html={data?.descriptionHtmlSimple || data?.description || ''}>
        
    </p>

    <div class="product-detail__add">
        <button id="addToCart" data-id={productId}>Add to Cart</button>
    </div>
      </>
    ) : (
      <>
      <h2 class="divider">Product not found</h2>
      <p class="product-error" role="alert">We couldn&apos;t find that product. Please choose another item.</p>
      </>
    )}
    </section>
  
</Layout>