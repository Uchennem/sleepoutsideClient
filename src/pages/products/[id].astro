---
import Layout from "../../layouts/Layout.astro";
import ImageCarousel from "../../components/ImageCarousel.svelte";

// map through all products to create a page for each one
export async function getStaticPaths() {
  // @ts-ignore - Node built-ins are available at Astro build time
  const { readFile } = await import("fs/promises");
  // @ts-ignore - Node built-ins are available at Astro build time
  const { fileURLToPath } = await import("url");
  const productDataFiles = ["tents.json", "backpacks.json", "sleeping-bags.json"];

  const normalizeProducts = (source: unknown) => {
    if (Array.isArray(source)) return source;
    if (source && typeof source === "object" && Array.isArray((source as any).Result)) {
      return (source as any).Result;
    }
    return [];
  };

  const productFileReads = productDataFiles.map(async (fileName) => {
    const filePath = fileURLToPath(new URL(`../../../public/json/${fileName}`, import.meta.url));
    const fileText = await readFile(filePath, "utf-8");
    return normalizeProducts(JSON.parse(fileText));
  });

  const products = (await Promise.all(productFileReads)).flat();

  return products
    .map((item: any) => {
      const id = item?.id ?? item?.Id;
      if (!id) return null;

      return {
        params: { id: String(id) },
        props: { data: item }
      };
    })
    .filter(Boolean);
}

// get the product data from the props to use in the template below. The actual data is in product.data
const product = Astro.props as { data?: any };
const data = product?.data;
const productId = data?.id ?? data?.Id;
const hasProduct = Boolean(data && productId);
const title = hasProduct ? (data?.name ?? data?.Name ?? "Product") : "Product Not Found";
const brandName = data?.brand?.name ?? data?.Brand?.Name ?? data?.brand ?? data?.Brand ?? "Brand";
const nameWithoutBrand = data?.nameWithoutBrand ?? data?.NameWithoutBrand ?? data?.name ?? data?.Name ?? "Product";
const imageSmall =
  data?.images?.primarySmall ??
  data?.Images?.PrimarySmall ??
  data?.images?.primaryMedium ??
  data?.Images?.PrimaryMedium ??
  data?.image ??
  data?.Image ??
  "/banner.jpg";
const imageMedium =
  data?.images?.primaryMedium ??
  data?.Images?.PrimaryMedium ??
  imageSmall;
const imageLarge =
  data?.images?.primaryLarge ??
  data?.Images?.PrimaryLarge ??
  imageMedium;
const imageExtraLarge =
  data?.images?.primaryExtraLarge ??
  data?.Images?.PrimaryExtraLarge ??
  imageLarge;
const displayPrice = data?.finalPrice ?? data?.FinalPrice ?? data?.price ?? data?.ListPrice ?? "Price TBA";
const colorName = data?.colors?.[0]?.colorName ?? data?.Colors?.[0]?.ColorName ?? data?.color ?? data?.Color ?? "";
const description =
  data?.descriptionHtmlSimple ??
  data?.DescriptionHtmlSimple ??
  data?.description ??
  data?.Description ??
  "";

function formatCategoryLabel(value: string) {
  return value
    .split("-")
    .map((part) => part.charAt(0).toUpperCase() + part.slice(1))
    .join(" ");
}

const category = data?.category ?? data?.Category ?? "";
const breadcrumb = category ? formatCategoryLabel(category) : "";

// Extract extra images for carousel
const extraImages = data?.images?.extraImages ?? data?.Images?.ExtraImages ?? [];
const carouselImages = [
  {
    src: imageExtraLarge,
    srcset: `${imageSmall} 80w, ${imageMedium} 160w, ${imageLarge} 320w, ${imageExtraLarge} 600w`,
    sizes: "(max-width: 600px) 95vw, 600px",
    alt: nameWithoutBrand
  },
  ...(Array.isArray(extraImages) ? extraImages.map((img: any) => ({
    src: img.Src ?? img.src ?? "",
    alt: img.Title ?? img.title ?? nameWithoutBrand
  })) : [])
];
---
<Layout title = {title} breadcrumb={breadcrumb} showBreadcrumb={Boolean(breadcrumb)}>
    {hasProduct && (
      <script type="application/json" id="product-data" set:html={JSON.stringify(data)}></script>
    )}
    <script src="../../js/product.ts"></script>
  
    <!-- Product details will go here -->
    <section class="product-detail">
    {hasProduct ? (
      <>
    <h3>{brandName}</h3>

    <h2 class="divider">{nameWithoutBrand}</h2>

    <ImageCarousel images={carouselImages} client:load />

    <p class="product-card__price">{displayPrice}</p>

    <p class="product__color">{colorName}</p>

    <p class="product__description" set:html={description}>
        
    </p>

    <div class="product-detail__add">
        <button id="addToCart" data-id={productId}>Add to Cart</button>
    </div>
      </>
    ) : (
      <>
      <h2 class="divider">Product not found</h2>
      <p class="product-error" role="alert">We couldn&apos;t find that product. Please choose another item.</p>
      </>
    )}
    </section>
  
</Layout>
